<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/game_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_light_background"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding_small">

        <!-- TOP STATE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/md_theme_light_primaryContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/screen_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/table_state"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/md_theme_light_onPrimaryContainer" />

                <TextView
                    android:id="@+id/status_txt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:text="@string/waiting_for_game_state"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/md_theme_light_onPrimaryContainer" />

                <TextView
                    android:id="@+id/top_card_status_txt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/top_card_fallback"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/md_theme_light_onPrimaryContainer" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TOP CARD PREVIEW -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            app:cardBackgroundColor="@color/md_theme_light_surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/md_theme_light_outline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <FrameLayout
                    android:id="@+id/top_card_preview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:foregroundGravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PLAYERS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            app:cardBackgroundColor="@color/md_theme_light_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_sm">

                <!-- PLAYER 1 -->
                <LinearLayout
                    android:id="@+id/player_1_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_sm">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/p1_name_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/md_theme_light_onSurface"
                            tools:text="Player 1" />

                        <TextView
                            android:id="@+id/p1_cards_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"
                            tools:text="has 8 cards" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/penalty_p1"
                        style="@style/Widget.UNO.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="@string/penalty" />
                </LinearLayout>

                <!-- PLAYER 2 -->
                <LinearLayout
                    android:id="@+id/player_2_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_sm">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/p2_name_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/md_theme_light_onSurface"
                            tools:text="Player 2" />

                        <TextView
                            android:id="@+id/p2_cards_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"
                            tools:text="has 8 cards" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/penalty_p2"
                        style="@style/Widget.UNO.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/penalty" />
                </LinearLayout>

                <!-- PLAYER 3 -->
                <LinearLayout
                    android:id="@+id/player_3_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_sm">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/p3_name_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/md_theme_light_onSurface"
                            tools:text="Player 3" />

                        <TextView
                            android:id="@+id/p3_cards_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"
                            tools:text="has 8 cards" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/penalty_p3"
                        style="@style/Widget.UNO.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/penalty" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/take_card_btn"
                style="@style/Widget.UNO.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="@dimen/space_sm"
                android:text="@string/take_a_card" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/uno_call_btn"
                style="@style/Widget.UNO.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/uno_short" />
        </LinearLayout>

        <!-- CARD CONTAINER -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            app:cardBackgroundColor="@color/md_theme_light_surfaceVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_md">

                <LinearLayout
                    android:id="@+id/card_container"
                    android:layout_width="wrap_content"
                    android:layout_height="110dp"
                    android:gravity="center_horizontal|bottom"
                    android:orientation="horizontal" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PLAY BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/draw_card_btn"
            style="@style/Widget.UNO.Button"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/play_selected_card" />

    </LinearLayout>

</ScrollView>