<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F2"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UNO Lobby"
        android:textColor="@color/colorPrimary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/connection_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Not connected"
        android:textColor="#334155"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/name_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@android:drawable/edit_text"
        android:hint="Your name"
        android:padding="12dp"
        android:textColor="#0F172A"
        android:textColorHint="#64748B" />

    <RadioGroup
        android:id="@+id/mode_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/host_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Host"
            android:textColor="#0F172A" />

        <RadioButton
            android:id="@+id/join_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Join"
            android:textColor="#0F172A" />
    </RadioGroup>

    <Button
        android:id="@+id/host_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Create Lobby" />

    <Button
        android:id="@+id/join_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Join Lobby"
        android:visibility="gone" />

    <TextView
        android:id="@+id/lobby_title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Lobby 0/2"
        android:textColor="#0F172A"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lobby_status_txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Create or join a lobby to begin."
        android:textColor="#475569"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/player_1_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            android:text="Waiting for player..."
            android:textColor="#0F172A"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player_2_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            android:text="Waiting for player..."
            android:textColor="#0F172A"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player_3_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            android:text="Waiting for player..."
            android:textColor="#0F172A"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player_4_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            android:text="Waiting for player..."
            android:textColor="#0F172A"
            android:textSize="16sp" />
    </LinearLayout>

    <Button
        android:id="@+id/ready_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Ready" />

    <Button
        android:id="@+id/start_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Start Game"
        android:visibility="gone" />

</LinearLayout>
